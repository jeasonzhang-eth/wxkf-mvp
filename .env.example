# ===== 企业微信「微信客服」MVP 配置 =====
# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略）

# 企业 ID（企业微信后台 -> 我的企业 -> 企业信息 -> 企业ID）
WXKF_CORPID=ww1234567890abcdef

# 微信客服的 Secret（企业微信后台 -> 微信客服 -> API -> Secret）
WXKF_SECRET=your_kf_secret_here

# 回调配置（企业微信后台 -> 微信客服 -> API -> 回调配置 里你自己设置/生成的）
WXKF_TOKEN=your_callback_token
WXKF_AES_KEY=your_43_char_encoding_aes_key

# 本地监听端口（nginx 反代到这里）
PORT=3000
